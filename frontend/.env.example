# API Configuration
VITE_API_BASE_URL=http://localhost:8000/v1

# AWS Configuration
VITE_AWS_REGION=ap-south-1
VITE_S3_BUCKET=trialmatch-documents

# Application Configuration
VITE_APP_NAME=TrialMatch AI
VITE_APP_VERSION=1.0.0
VITE_ENVIRONMENT=development

# Feature Flags
VITE_ENABLE_WHATSAPP_BOT=false
VITE_ENABLE_NOTIFICATIONS=false
VITE_ENABLE_MULTILINGUAL=true
VITE_ENABLE_ANALYTICS=false

# Upload Configuration
VITE_MAX_FILE_SIZE_MB=10
VITE_ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png

# Map Configuration (for trial locations)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Supported Languages
VITE_SUPPORTED_LANGUAGES=en,hi,ta,te,bn,mr

# Default Settings
VITE_DEFAULT_LANGUAGE=en
VITE_DEFAULT_MAX_DISTANCE_KM=100

# Development Settings
VITE_ENABLE_DEBUG_MODE=true
VITE_MOCK_API_RESPONSES=false
